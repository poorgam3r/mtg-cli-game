{
  "name": "mtg-cli-game",
  "version": "1.0.0",
  "description": "Magic: The Gathering CLI deck builder with Supabase and AWS Secrets Manager",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "prepare": "husky install",
    "start": "node dist/index.js",
    "dev": "ts-node index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "format": "prettier --write .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.500.0",
    "@supabase/supabase-js": "^2.39.6",
    "axios": "^1.6.7",
    "chalk": "^5.3.0",
    "inquirer": "^12.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/chalk": "^0.4.31",
    "@types/inquirer": "^9.0.8",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.4.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "globals": "^16.1.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.0.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "**/*.{js,ts,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "npx lint-staged"
    }
  }
}
